<Window x:Class="VideoGrid.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="NEXUS · Video Grid"
        Height="960" Width="1600"
        MinHeight="700" MinWidth="1100"
        Background="#0A0A0F"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <!-- 버튼 스타일 -->
        <Style x:Key="GlassButton" TargetType="Button">
            <Setter Property="Background" Value="#1A1A2E"/>
            <Setter Property="Foreground" Value="#E0E0FF"/>
            <Setter Property="BorderBrush" Value="#2A2A4A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="14,7"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#252545"/>
                                <Setter Property="BorderBrush" Value="#5A5AFF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#0D0D20"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="AccentButton" TargetType="Button" BasedOn="{StaticResource GlassButton}">
            <Setter Property="Background" Value="#1E1E5E"/>
            <Setter Property="BorderBrush" Value="#4444CC"/>
            <Setter Property="Foreground" Value="#AAAAFF"/>
        </Style>

        <Style x:Key="DangerButton" TargetType="Button" BasedOn="{StaticResource GlassButton}">
            <Setter Property="Background" Value="#2A1010"/>
            <Setter Property="BorderBrush" Value="#882222"/>
            <Setter Property="Foreground" Value="#FF8888"/>
        </Style>

        <Style x:Key="SuccessButton" TargetType="Button" BasedOn="{StaticResource GlassButton}">
            <Setter Property="Background" Value="#0D2A1A"/>
            <Setter Property="BorderBrush" Value="#226644"/>
            <Setter Property="Foreground" Value="#44FFAA"/>
        </Style>

        <!-- 스크롤바 스타일 -->
        <Style TargetType="ScrollBar">
            <Setter Property="Background" Value="#0A0A0F"/>
            <Setter Property="Width" Value="6"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="52"/>  <!-- 탑바 -->
            <RowDefinition Height="*"/>   <!-- 메인 콘텐츠 -->
            <RowDefinition Height="28"/>  <!-- 상태바 -->
        </Grid.RowDefinitions>

        <!-- ══════════════════ 탑바 ══════════════════ -->
        <Border Grid.Row="0" Background="#06060D"
                BorderBrush="#1A1A30" BorderThickness="0,0,0,1">
            <Grid Margin="16,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- 로고 -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Width="8" Height="8" Background="#5555FF" CornerRadius="2" Margin="0,0,8,0"/>
                    <TextBlock Text="NEXUS" Foreground="#FFFFFF" FontSize="15" FontWeight="Bold"
                               FontFamily="Segoe UI" VerticalAlignment="Center"/>
                    <TextBlock Text=" · VIDEO GRID" Foreground="#5555AA" FontSize="11"
                               FontFamily="Segoe UI" VerticalAlignment="Center" Margin="0,1,0,0"/>
                </StackPanel>

                <!-- URL 입력 -->
                <Border Grid.Column="1" Background="#10101E" BorderBrush="#222240"
                        BorderThickness="1" CornerRadius="8" Margin="24,10" Padding="12,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0" Text="🔗" VerticalAlignment="Center"
                                   Margin="0,0,8,0" FontSize="12"/>
                        <TextBox Grid.Column="1" x:Name="UrlInputBox"
                                 Background="Transparent" Foreground="#CCCCFF"
                                 BorderThickness="0" FontSize="12" FontFamily="Consolas"
                                 VerticalAlignment="Center" CaretBrush="#5555FF"
                                 Text="https://www.youtube.com/watch?v=..."
                                 GotFocus="UrlInputBox_GotFocus"
                                 KeyDown="UrlInputBox_KeyDown"/>
                        <Button Grid.Column="2" x:Name="AddButton"
                                Content="ADD +" Style="{StaticResource AccentButton}"
                                Click="AddUrl_Click" Height="28" FontSize="11" FontWeight="SemiBold"/>
                    </Grid>
                </Border>

                <!-- 컨트롤 버튼들 -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="▶ PLAY ALL" Style="{StaticResource SuccessButton}" Margin="0,0,6,0"
                            Click="PlayAll_Click" Height="30"/>
                    <Button Content="⏸ PAUSE ALL" Style="{StaticResource GlassButton}" Margin="0,0,6,0"
                            Click="StopAll_Click" Height="30"/>
                    <Button Content="✕ CLEAR" Style="{StaticResource DangerButton}"
                            Click="ClearAll_Click" Height="30"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ══════════════════ 메인 콘텐츠 ══════════════════ -->
        <Grid Grid.Row="1" Margin="10,10,10,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="180"/>  <!-- 왼쪽 사이드바: 재생목록 -->
                <ColumnDefinition Width="*"/>    <!-- 중앙: 메인+히스토리+썸네일 -->
            </Grid.ColumnDefinitions>

            <!-- ── 왼쪽 사이드바 ── -->
            <Border Grid.Column="0" Background="#08080F" BorderBrush="#1A1A2A"
                    BorderThickness="1" CornerRadius="10" Margin="0,0,8,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" Padding="14,12" BorderBrush="#1A1A2A" BorderThickness="0,0,0,1">
                        <StackPanel>
                            <TextBlock Text="PLAYLIST" Foreground="#4444AA" FontSize="9"
                                       FontFamily="Segoe UI" FontWeight="Bold"/>
                            <TextBlock x:Name="PlaylistCountText" Text="0 videos"
                                       Foreground="#444466" FontSize="11" FontFamily="Segoe UI" Margin="0,2,0,0"/>
                        </StackPanel>
                    </Border>
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <StackPanel x:Name="PlaylistPanel" Margin="8,8"/>
                    </ScrollViewer>
                </Grid>
            </Border>

            <!-- ── 오른쪽 메인 영역 ── -->
            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>    <!-- 상단: 메인뷰어 + 히스토리 -->
                    <RowDefinition Height="8"/>    <!-- 간격 -->
                    <RowDefinition Height="160"/>  <!-- 하단: 썸네일 그리드 -->
                </Grid.RowDefinitions>

                <!-- 상단: 메인뷰어 + 히스토리 -->
                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="240"/>
                    </Grid.ColumnDefinitions>

                    <!-- 메인 플레이어 -->
                    <Border Grid.Column="0" Background="#05050E"
                            BorderBrush="#2222AA" BorderThickness="1" CornerRadius="10"
                            x:Name="MainPlayerBorder">
                        <Grid>
                            <wv2:WebView2 x:Name="MainWebView" Visibility="Collapsed"/>
                            <StackPanel x:Name="MainPlaceholder"
                                        HorizontalAlignment="Center" VerticalAlignment="Center">
                                <TextBlock Text="▶" Foreground="#1E1E4E" FontSize="48"
                                           HorizontalAlignment="Center"/>
                                <TextBlock Text="MAIN PLAYER" Foreground="#1E1E4E" FontSize="13"
                                           FontFamily="Segoe UI" FontWeight="Bold"
                                           HorizontalAlignment="Center" Margin="0,12,0,0"/>
                                <TextBlock Text="썸네일을 클릭하거나 URL을 추가하세요"
                                           Foreground="#151530" FontSize="11" FontFamily="Segoe UI"
                                           HorizontalAlignment="Center" Margin="0,6,0,0"/>
                            </StackPanel>
                            <!-- 현재 재생 제목 오버레이 -->
                            <Border VerticalAlignment="Bottom" HorizontalAlignment="Stretch"
                                    Background="#AA000010" Padding="12,8" CornerRadius="0,0,10,10">
                                <TextBlock x:Name="MainTitleText" Text=""
                                           Foreground="#AAAAFF" FontSize="11" FontFamily="Segoe UI"
                                           TextTrimming="CharacterEllipsis"/>
                            </Border>
                        </Grid>
                    </Border>

                    <!-- 히스토리 사이드 패널 -->
                    <Border Grid.Column="2" Background="#06060D"
                            BorderBrush="#1A1A2A" BorderThickness="1" CornerRadius="10">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="8"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <Border Grid.Row="0" Padding="12,10" BorderBrush="#1A1A2A" BorderThickness="0,0,0,1">
                                <TextBlock Text="RECENTLY PLAYED" Foreground="#4444AA" FontSize="9"
                                           FontFamily="Segoe UI" FontWeight="Bold"/>
                            </Border>

                            <!-- [FIX] 히스토리 1: 불필요한 MouseBinding 제거, MouseLeftButtonUp으로 통일 -->
                            <Border Grid.Row="1" x:Name="History1Border"
                                    Background="#08080F" Margin="8,8,8,0"
                                    BorderBrush="#1A1A2A" BorderThickness="1" CornerRadius="8"
                                    Cursor="Hand">
                                <Grid>
                                    <wv2:WebView2 x:Name="History1WebView" Visibility="Collapsed" IsHitTestVisible="False"/>
                                    <StackPanel x:Name="History1Placeholder"
                                                HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <TextBlock Text="PREV 1" Foreground="#1A1A3A" FontSize="11"
                                                   FontFamily="Segoe UI" FontWeight="Bold"
                                                   HorizontalAlignment="Center"/>
                                    </StackPanel>
                                    <Border VerticalAlignment="Bottom" Background="#BB000008"
                                            Padding="8,5" CornerRadius="0,0,8,8">
                                        <TextBlock x:Name="History1Title" Text=""
                                                   Foreground="#7777AA" FontSize="10" FontFamily="Segoe UI"
                                                   TextTrimming="CharacterEllipsis"/>
                                    </Border>
                                </Grid>
                            </Border>

                            <!-- [FIX] 히스토리 2: 불필요한 MouseBinding 제거, MouseLeftButtonUp으로 통일 -->
                            <Border Grid.Row="3" x:Name="History2Border"
                                    Background="#08080F" Margin="8,0,8,8"
                                    BorderBrush="#1A1A2A" BorderThickness="1" CornerRadius="8"
                                    Cursor="Hand">
                                <Grid>
                                    <wv2:WebView2 x:Name="History2WebView" Visibility="Collapsed" IsHitTestVisible="False"/>
                                    <StackPanel x:Name="History2Placeholder"
                                                HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <TextBlock Text="PREV 2" Foreground="#1A1A3A" FontSize="11"
                                                   FontFamily="Segoe UI" FontWeight="Bold"
                                                   HorizontalAlignment="Center"/>
                                    </StackPanel>
                                    <Border VerticalAlignment="Bottom" Background="#BB000008"
                                            Padding="8,5" CornerRadius="0,0,8,8">
                                        <TextBlock x:Name="History2Title" Text=""
                                                   Foreground="#7777AA" FontSize="10" FontFamily="Segoe UI"
                                                   TextTrimming="CharacterEllipsis"/>
                                    </Border>
                                </Grid>
                            </Border>
                        </Grid>
                    </Border>
                </Grid>

                <!-- [FIX] 하단 썸네일 그리드: Columns=4, Rows=5 로 수정 (원래 20×1은 너무 좁음) -->
                <Border Grid.Row="2" Background="#06060D"
                        BorderBrush="#1A1A2A" BorderThickness="1" CornerRadius="10">
                    <Grid Margin="8,6">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Text="CHANNELS" Foreground="#4444AA" FontSize="9"
                                   FontFamily="Segoe UI" FontWeight="Bold" Margin="4,0,0,4"/>
                        <UniformGrid Grid.Row="1" x:Name="ThumbnailGrid" Columns="4" Rows="1"/>
                    </Grid>
                </Border>
            </Grid>
        </Grid>

        <!-- ══════════════════ 상태바 ══════════════════ -->
        <Border Grid.Row="2" Background="#04040A"
                BorderBrush="#111120" BorderThickness="0,1,0,0">
            <Grid Margin="16,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="StatusText" Grid.Column="0"
                           Foreground="#333355" FontSize="10" FontFamily="Consolas"
                           VerticalAlignment="Center"
                           Text="NEXUS VIDEO GRID · Ready"/>
                <TextBlock x:Name="CountText" Grid.Column="1"
                           Foreground="#333366" FontSize="10" FontFamily="Consolas"
                           VerticalAlignment="Center" Text="0 / 20"/>
            </Grid>
        </Border>
    </Grid>
</Window>
