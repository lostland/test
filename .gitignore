## .gitignore for C# / WPF / .NET

# Build results
bin/
obj/
out/

# User-specific files
*.user
*.suo
*.userosscache
*.sln.docstates

# Visual Studio files
.vs/
*.rsuser

# NuGet
packages/
*.nupkg
project.lock.json
project.fragment.lock.json
artifacts/

# Publish output
publish/

# OS
.DS_Store
Thumbs.db

# Temp files generated by VideoGrid
videogrid_*.html
